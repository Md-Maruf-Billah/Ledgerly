# Ledgerly — Frontend Environment Variables
# Copy this file to .env.local for local development.
# Never commit .env.local or any file containing real keys.

# Backend API base URL (local development)
VITE_API_BASE_URL=http://localhost:8000

# Supabase — leave empty until Supabase project is created
# These are ANON/PUBLIC keys only. Never put service role key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
