# Ledgerly — Backend Environment Variables
# Copy this file to .env for local development.
# Never commit .env to version control.

APP_ENV=local

# CORS — comma-separated list of allowed frontend origins
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Supabase — leave empty until Supabase project is created
# NEVER expose SUPABASE_SERVICE_ROLE_KEY to the frontend.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database connection (Supabase Postgres, filled later)
DATABASE_URL=

# JWT secret for session tokens (generate a strong random string)
SECRET_KEY=replace-with-a-strong-random-secret
